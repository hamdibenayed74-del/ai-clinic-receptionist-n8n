        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"required\": [\"intent\", \"phone\", \"language\", \"reply_to_patient\", \"ready_for_scheduling\"],\n  \"properties\": {\n    \"intent\": { \"type\": \"string\", \"enum\": [\"new_appointment\", \"reschedule_appointment\", \"cancel_appointment\", \"emergency\", \"information_request\", \"clinic_hours\", \"doctor_availability\", \"unclear\"] },\n    \"patient_name\": { \"type\": [\"string\", \"null\"] },\n    \"phone\": { \"type\": \"string\" },\n    \"language\": { \"type\": \"string\", \"enum\": [\"fr\", \"ar\", \"en\"] },\n    \"doctor\": { \"type\": [\"string\", \"null\"] },\n    \"preferred_date\": { \"type\": [\"string\", \"null\"] },\n    \"preferred_time\": { \"type\": [\"string\", \"null\"] },\n    \"duration\": { \"type\": [\"integer\", \"null\"] },\n    \"reason\": { \"type\": [\"string\", \"null\"] },\n    \"existing_appointment_id\": { \"type\": [\"string\", \"null\"] },\n    \"missing_fields\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n    \"reply_to_patient\": { \"type\": \"string\" },\n    \"ready_for_scheduling\": { \"type\": \"boolean\" }\n  }\n}"
