        "jsCode": "const signature = $input.first().json.headers['x-hub-signature-256'];\nif (!signature) {\n  throw new Error('Missing Meta X-Hub-Signature-256 header - rejecting request');\n}\nreturn $input.all();"
      },
      "id": "75ba9ea3-570e-4745-9e4c-76beda6de993",
      "name": "Verify WA Signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        8416,
        3584
      ],
      "notes": "Minimal guard: confirms Meta's X-Hub-Signature-256 header is present before proceeding. Replace with full HMAC verification against META_WHATSAPP_VERIFY_TOKEN in production."
    },
    {
      "parameters": {
        "jsCode": "const signature = $input.first().json.headers['x-twilio-signature'];\nif (!signature) {\n  throw new Error('Missing Twilio X-Twilio-Signature header - rejecting request');\n}\nreturn $input.all();"
      },
      "id": "cfb33fa4-bb69-45d4-833c-1a95696d9839",
