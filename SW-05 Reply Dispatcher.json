      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const allowedEvents = [\n  'Greeting', 'Appointment Confirmation', 'Appointment Cancellation', 'Appointment Reschedule',\n  'Reminder', 'Follow-up', 'Human Handoff', 'Error', 'Emergency', 'General Information'\n];\n\nconst languageMap = {\n  'french': 'fr', 'francais': 'fr', 'fran\\u00e7ais': 'fr', 'fr': 'fr', 'fr-fr': 'fr',\n  'arabic': 'ar', 'arabe': 'ar', 'ar': 'ar', 'ar-tn': 'ar', 'ar-ma': 'ar',\n  'english': 'en', 'anglais': 'en', 'en': 'en', 'en-us': 'en', 'en-gb': 'en'\n};\n\nconst rawLanguage = ($json.language || '').toString().trim().toLowerCase();\nconst language = languageMap[rawLanguage] || 'fr';\n\nconst event = $json.event;\nconst workflow_source = $json.workflow_source || 'unknown';\nconst patient_name = $json.patient_name || '';\nconst payload = $json.payload || {};\nconst channel = (payload.channel || payload.source_channel || 'whatsapp').toString().toLowerCase();\nconst clinic_id = payload.clinic_id || 'default';\n\nif (!event || !allowedEvents.includes(event)) {\n  return { json: { valid: false, error: `Unsupported or missing event: \"${event}\"`, event: event || null, language, channel, workflow_source, patient_name, payload, clinic_id } };\n}\n\nreturn { json: { valid: true, error: null, event, language, channel, workflow_source, patient_name, payload, clinic_id } };"
      },
