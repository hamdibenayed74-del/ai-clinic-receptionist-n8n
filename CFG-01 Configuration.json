        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const allowedActions = [\n  'getClinicInfo', 'getDoctors', 'getDoctorSchedule', 'getBusinessHours',\n  'getAppointmentTypes', 'getSupportedLanguages', 'getTimezone',\n  'getHolidayCalendar', 'getReminderSettings', 'getAIConfiguration'\n];\n\nconst action = $json.action;\nconst clinic_id = $json.clinic_id || 'default';\nconst doctor_id = $json.doctor_id || null;\n\nif (!action || !allowedActions.includes(action)) {\n  return { json: { valid: false, error: `Unsupported or missing action: \"${action}\"`, action: action || null, clinic_id, doctor_id } };\n}\n\nif (action === 'getDoctorSchedule' && !doctor_id) {\n  return { json: { valid: false, error: 'doctor_id is required for getDoctorSchedule', action, clinic_id, doctor_id } };\n}\n\nreturn { json: { valid: true, error: null, action, clinic_id, doctor_id } };"
      },
