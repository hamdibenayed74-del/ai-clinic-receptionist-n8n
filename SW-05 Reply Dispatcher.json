        "jsCode": "const ctx = $('Prepare AI Context').first().json;\nconst raw = $json.text !== undefined ? $json.text : ($json.response !== undefined ? $json.response : $json.output);\nconst text = (raw || '').toString().trim();\n\nif (!text) {\n  return { json: { ai_failed: true, channel: ctx.channel, language: ctx.language } };\n}\n\nreturn { json: { message: text, template_id: 'ai_generated', channel: ctx.channel, language: ctx.language } };"
      },
