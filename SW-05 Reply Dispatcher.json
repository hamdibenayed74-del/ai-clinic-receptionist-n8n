    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst ctx = $('Build Merged Context').first().json;\n\nif (rows.length === 0) {\n  return [{ json: { ...ctx, found: false } }];\n}\n\nlet match = rows.find(r => r.channel === ctx.channel);\nif (!match) match = rows.find(r => !r.channel || r.channel === 'any' || r.channel === '');\nif (!match) match = rows[0];\n\nreturn [{ json: { ...ctx, found: true, template_id: match.template_id, template_body: match.template_body } }];"
      },
      "id": "0151ab5b-7553-4541-9db7-e763f6dc4ee2",
      "name": "Pick Best Template",
