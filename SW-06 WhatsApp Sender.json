{
  "name": "SW-06 WhatsApp Sender",
  "nodes": [
    {
      "parameters": {
        "content": "SW-06 WhatsApp Sender\n\nPurpose\n\nDedicated delivery workflow for WhatsApp messages.\n\nResponsibilities\n\n• Validate outbound requests\n• Build WhatsApp API payload\n• Send message\n• Retry failed deliveries\n• Log delivery status\n\nConsumers\n\n• SW-05 Reply Dispatcher",
        "height": 396,
        "width": 520
      },
      "id": "118660e1-aedf-4088-8953-f3fb668925a2",
      "name": "Sticky Note - Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        336,
        128
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const allowedTypes = ['text', 'image', 'document', 'interactive'];\n\nconst recipient = ($json.recipient || '').toString().trim();\nconst message_type = ($json.message_type || 'text').toString().trim().toLowerCase();\nconst message = $json.message || '';\nconst attachments = Array.isArray($json.attachments) ? $json.attachments : [];\nconst language = $json.language || '';\nconst metadata = $json.metadata || {};\nconst phoneDigits = recipient.replace(/[^0-9]/g, '');\n\nconst base = { recipient, message_type, message, attachments, language, metadata };\n\nif (!recipient || phoneDigits.length < 8) {\n  return { json: { valid: false, error: 'A valid recipient phone number is required.', ...base } };\n}\n\nif (!allowedTypes.includes(message_type)) {\n  return { json: { valid: false, error: `Unsupported message_type: \"${message_type}\"`, ...base } };\n}\n\nif (message_type === 'text' && !message) {\n  return { json: { valid: false, error: 'message is required for message_type \"text\".', ...base } };\n}\n\nif ((message_type === 'image' || message_type === 'document') && (attachments.length === 0 || !(attachments[0].url || attachments[0].id))) {\n  return { json: { valid: false, error: `attachments[0].url or attachments[0].id is required for message_type \"${message_type}\".`, ...base } };\n}\n\nif (message_type === 'interactive' && !metadata.interactive_type) {\n  return { json: { valid: false, error: 'metadata.interactive_type (\"button\" or \"list\") is required for message_type \"interactive\".', ...base } };\n}\n\nreturn { json: { valid: true, error: null, ...base } };"
      },
      "id": "9a780e3f-8dbd-4dfd-9eb6-7dbd9ca2e246",
      "name": "Validate Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        640
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
          "conditions": [
            {
              "id": "v1",
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "d6e7f99e-c6c4-4247-9fba-1a151218da58",
      "name": "IF: Valid Request",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        928,
        640
