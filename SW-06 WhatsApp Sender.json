    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const ctx = $json;\nconst to = ctx.recipient.replace(/[^0-9]/g, '');\nlet payload = { messaging_product: 'whatsapp', to, type: ctx.message_type };\n\nif (ctx.message_type === 'text') {\n  payload.text = { body: ctx.message, preview_url: false };\n}\n\nif (ctx.message_type === 'image') {\n  const att = ctx.attachments[0];\n  payload.image = att.id ? { id: att.id } : { link: att.url };\n  if (ctx.message) payload.image.caption = ctx.message;\n}\n\nif (ctx.message_type === 'document') {\n  const att = ctx.attachments[0];\n  payload.document = att.id ? { id: att.id } : { link: att.url };\n  if (att.filename) payload.document.filename = att.filename;\n  if (ctx.message) payload.document.caption = ctx.message;\n}\n\nif (ctx.message_type === 'interactive') {\n  const meta = ctx.metadata || {};\n  if (meta.interactive_type === 'button') {\n    payload.interactive = {\n      type: 'button',\n      body: { text: ctx.message || '' },\n      action: {\n        buttons: (meta.buttons || []).slice(0, 3).map((b, idx) => ({\n          type: 'reply',\n          reply: { id: b.id || `btn_${idx}`, title: (b.title || '').substring(0, 20) }\n        }))\n      }\n    };\n  } else if (meta.interactive_type === 'list') {\n    payload.interactive = {\n      type: 'list',\n      body: { text: ctx.message || '' },\n      action: {\n        button: meta.list_button_text || 'Options',\n        sections: meta.list_sections || []\n      }\n    };\n  } else {\n    payload = { messaging_product: 'whatsapp', to, type: 'text', text: { body: ctx.message || '' } };\n  }\n}\n\nreturn { json: { whatsapp_payload: payload, recipient: ctx.recipient, message_type: ctx.message_type, language: ctx.language, metadata: ctx.metadata } };"
      },
