    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const ctx = $json;\nconst p = ctx.payload || {};\nconst appt = p.appointment || {};\n\nconst vars = {\n  patient_name: ctx.patient_name || '',\n  clinic_name: ctx.clinic_name || '',\n  clinic_phone: ctx.clinic_phone || '',\n  clinic_address: ctx.clinic_address || '',\n  doctor: p.doctor || appt.doctor || '',\n  date: p.date || appt.date || '',\n  time: p.time || appt.time || '',\n  reason: p.reason || appt.reason || '',\n  slots: Array.isArray(p.slots) ? p.slots.join(', ') : '',\n  rejection_reason: p.rejection_reason || ''\n};\n\nlet message = ctx.template_body || '';\nfor (const [key, value] of Object.entries(vars)) {\n  message = message.split('{{' + key + '}}').join(String(value));\n}\n\nreturn { json: { message, template_id: ctx.template_id, channel: ctx.channel, language: ctx.language } };"
      },
