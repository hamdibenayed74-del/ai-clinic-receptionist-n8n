      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const ctx = $('Validate Request').first().json;\nconst cfgResult = $json;\nlet clinicData = {};\nif (cfgResult && cfgResult.success && cfgResult.data) {\n  clinicData = cfgResult.data;\n}\n\nreturn { json: {\n  event: ctx.event,\n  language: ctx.language,\n  channel: ctx.channel,\n  patient_name: ctx.patient_name,\n  payload: ctx.payload,\n  workflow_source: ctx.workflow_source,\n  clinic_name: clinicData.clinic_name || null,\n  clinic_phone: clinicData.phone || null,\n  clinic_whatsapp: clinicData.whatsapp_number || null,\n  clinic_address: clinicData.address || null\n} };"
      },
