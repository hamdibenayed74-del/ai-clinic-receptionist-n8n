      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let ctx;\nif ($json && $json.channel && $json.language && !$json.message) {\n  ctx = $json;\n} else {\n  ctx = $('Prepare AI Context').first().json;\n}\n\nconst language = (ctx.language || 'fr').toLowerCase();\nconst fallback = {\n  fr: \"Merci pour votre message. Un membre de notre \\u00e9quipe reviendra vers vous tr\\u00e8s prochainement.\",\n  ar: \"\\u0634\\u0643\\u0631\\u0627\\u064b \\u0644\\u062a\\u0648\\u0627\\u0635\\u0644\\u0643\\u0645 \\u0645\\u0639\\u0646\\u0627. \\u0633\\u064a\\u062a\\u0648\\u0627\\u0635\\u0644 \\u0645\\u0639\\u0643\\u0645 \\u0623\\u062d\\u062f \\u0623\\u0641\\u0631\\u0627\\u062f \\u0641\\u0631\\u064a\\u0642\\u0646\\u0627 \\u0641\\u064a \\u0623\\u0642\\u0631\\u0628 \\u0648\\u0642\\u062a \\u0645\\u0645\\u0643\\u0646.\",\n  en: \"Thank you for reaching out. A team member will get back to you shortly.\"\n};\nconst message = fallback[language] || fallback.fr;\n\nreturn { json: { message, template_id: 'generic_fallback', channel: ctx.channel, language: ctx.language } };"
